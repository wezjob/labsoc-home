# ============================================
# Mailu Configuration - SOC-PME Full Stack
# Fichier principal de configuration mail
# ============================================

###################################
# Common configuration variables
###################################

# Set to a randomly generated 16 bytes string
SECRET_KEY=ChangeThisToRandomString64Chars!

# Main domain for the mail server
DOMAIN=soc-pme.local

# Hostnames for this server
HOSTNAMES=mail.soc-pme.local

# Postmaster local part (postmaster@soc-pme.local)
POSTMASTER=admin

# Choose how you want to expose the services
# - none: no external exposure
# - subnet: limit to local networks
# - all: expose to all networks
BIND_ADDRESS=172.16.20.1

# IPv6 binding
BIND_ADDRESS6=::1

# Message size limit in bytes (default 50MB)
MESSAGE_SIZE_LIMIT=52428800

# Relayhosts - separate by ; for multiple
RELAYHOSTS=

# Address where bounces should be returned
BOUNCE_ADDRESS=admin@soc-pme.local

###################################
# Web settings
###################################

# Expose admin interface
ADMIN=true

# Choose between roundcube and snappymail
WEBMAIL=roundcube

# Calendar/contacts - none, radicale
WEBDAV=none

# Admin panel URL path
WEB_ADMIN=/admin

# Webmail URL path
WEB_WEBMAIL=/webmail

###################################
# Authentication settings
###################################

# Authentication rate limit (per IP, per user)
AUTH_RATELIMIT_IP=60/hour
AUTH_RATELIMIT_USER=100/day

###################################
# Antispam settings
###################################

# Antispam solution - rspamd
ANTISPAM=rspamd

# Enable antispam
ANTISPAM_ENABLED=true

# Enable greylist for unknown messages
GREYLISTING_ENABLED=true

###################################
# Antivirus settings
###################################

# Antivirus solution - clamav, none
ANTIVIRUS=clamav

# ClamAV max file size to scan
CLAMAV_MAX_FILE_SIZE=25M

###################################
# Database settings
###################################

# Database backend - postgresql, mysql, sqlite
DB_FLAVOR=postgresql
DB_HOST=postgres
DB_NAME=mailu
DB_USER=socpme
DB_PW=ChangeThisSecurePassword!

###################################
# Cache settings
###################################

# Redis for caching
CACHE_REDIS_URL=redis://redis/2

###################################
# Logging settings
###################################

# Log level (CRITICAL, ERROR, WARNING, INFO, DEBUG)
LOG_LEVEL=WARNING

# Log destination (syslog, stdout)
LOG_DRIVER=syslog

# Syslog address for logging
SYSLOG_ADDRESS=udp://logstash:5515

###################################
# TLS settings
###################################

# TLS flavor - notls, mail, mail-letsencrypt, cert
TLS_FLAVOR=mail

# Path to certificates if TLS_FLAVOR=cert
TLS_CERT_PATH=/certs/fullchain.pem
TLS_KEY_PATH=/certs/privkey.pem

###################################
# Outbound mail settings
###################################

# DKIM signing
DKIM_SELECTOR=dkim

# DKIM key size
DKIM_KEY_SIZE=2048

###################################
# DMARC reporting
###################################

# Email for DMARC reports
DMARC_RUA=admin@soc-pme.local
DMARC_RUF=admin@soc-pme.local

###################################
# Quota settings
###################################

# Default quota for new mailboxes (in bytes, 0 for unlimited)
DEFAULT_QUOTA=5368709120  # 5GB

###################################
# Network settings
###################################

# Subnet (Docker internal)
SUBNET=172.18.0.0/24

# Networks allowed to send without authentication (internal)
RELAYNETS=172.16.0.0/12
